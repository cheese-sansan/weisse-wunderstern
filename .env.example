# Optional OpenAI-compatible LLM configuration.
# Leave OPENAI_API_KEY empty to use Mock mode.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Literature retrieval. Crossref is real metadata retrieval and needs no key.
# Use mock or llm-simulated only for explicit offline demonstrations.
LITERATURE_PROVIDER=crossref
LITERATURE_MAX_RESULTS=10
LITERATURE_TIMEOUT_SECONDS=10
CROSSREF_MAILTO=

# Optional API authentication.
# When set, /api/v1/jobs/* requires Authorization: Bearer <API_TOKEN>.
API_TOKEN=

# API and runtime settings.
API_PORT=8000
MAX_UPLOAD_SIZE_MB=50
JOB_RETENTION_DAYS=7
LOG_LEVEL=INFO

# Docker build settings.
PYTHON_IMAGE=python:3.10-slim
INSTALL_EXTRAS=false
